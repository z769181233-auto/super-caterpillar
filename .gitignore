api_direct.log

# ============================
# Evidence vs Release Hygiene (SSOT)
# ============================

# Default: ignore logs & outs everywhere (Release Surface)
*.log
*.out

# Evidence roots must be traversable
!docs/_evidence/
!docs/_evidence/**/
!docs/_evidence_archived/
!docs/_evidence_archived/**/

# Evidence surface: allow audit logs/outs as artifacts
!docs/_evidence/**/*.log
!docs/_evidence/**/*.out
!docs/_evidence_archived/**/*.log
!docs/_evidence_archived/**/*.out

# Evidence surface: still ban noisy runtime logs (keep audit snapshots only)
docs/_evidence/**/api.log
docs/_evidence/**/worker.log
docs/_evidence/**/gate.log
docs/_evidence_archived/**/api.log
docs/_evidence_archived/**/worker.log
docs/_evidence_archived/**/gate.log
