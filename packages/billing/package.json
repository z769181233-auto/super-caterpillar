{
  "name": "@scu/billing",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./model-price-table": {
      "types": "./dist/model-price-table.d.ts",
      "default": "./dist/model-price-table.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup index.ts model-price-table.ts --format cjs --dts --clean"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
