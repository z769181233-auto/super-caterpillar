// ============================================
// Stage 4: Asset System (MVP)
// ============================================

model Asset {
  id             String         @id @default(uuid())
  projectId      String
  ownerType      AssetOwnerType
  ownerId        String
  type           AssetType
  status         AssetStatus    @default(GENERATED)
  storageKey     String
  checksum       String? // SHA256/MD5
  createdByJobId String?
  createdAt      DateTime       @default(now())

  // Relations
  project Project  @relation("ProjectAssets", fields: [projectId], references: [id], onDelete: Cascade)
  job     ShotJob? @relation("JobGeneratedAsset", fields: [createdByJobId], references: [id], onDelete: SetNull)
  shot    Shot?    @relation("ShotAssets", fields: [ownerId], references: [id], onDelete: Cascade, map: "Asset_Shot_fkey") // Optional: logical link if ownerType=SHOT

  // Stage 10 Refactor: Business Key Idempotency (One Asset per Type per Owner)
  @@unique([ownerType, ownerId, type])
  @@index([projectId])
  @@index([ownerType, ownerId])
  @@map("assets")
}

// ============================================
// Stage 11: Text Safety System
// ============================================

model TextSafetyResult {
  id              String             @id @default(uuid())
  resourceType    String // 'NOVEL_SOURCE' | 'JOB' | 'SCENE_DRAFT'
  resourceId      String
  decision        TextSafetyDecision
  riskLevel       RiskLevel
  flags           Json               @default("[]")
  reasons         Json               @default("[]")
  sanitizedDigest String? // SHA256(sanitizedText)
  traceId         String?
  createdAt       DateTime           @default(now())

  @@index([resourceType, resourceId])
  @@index([decision, createdAt(sort: Desc)])
  @@index([riskLevel, createdAt(sort: Desc)])
  @@map("text_safety_results")
}

enum AssetOwnerType {
  SCENE
  SHOT
}

enum AssetType {
  IMAGE
  VIDEO
  MODEL
}

enum AssetStatus {
  GENERATED
  LOCKED
  PUBLISHED
}
