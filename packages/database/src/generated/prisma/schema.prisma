model Asset {
  id             String         @id @default(uuid())
  projectId      String
  createdAt      DateTime       @default(now())
  checksum       String?
  createdByJobId String?
  ownerId        String
  ownerType      AssetOwnerType
  status         AssetStatus    @default(GENERATED)
  storageKey     String
  type           AssetType
  shotId         String?
  shot           Shot?          @relation("ShotAssets", fields: [shotId], references: [id], onDelete: Cascade)
  job            ShotJob?       @relation("JobGeneratedAsset", fields: [createdByJobId], references: [id])
  project        Project        @relation("ProjectAssets", fields: [projectId], references: [id], onDelete: Cascade)

  // Security Fields (DBSpec V1.1)
  hlsPlaylistUrl String? @map("hls_playlist_url")
  signedUrl      String? @map("signed_url")
  watermarkMode  String? @map("watermark_mode")
  fingerprintId  String? @map("fingerprint_id")

  // Commercial Delivery Fields (Phase-B Alias for clarity if needed, but we keep existing mappings)
  // The user requested: signed_url, hls_playlist_url, watermark_mode, fingerprint_id
  // These are already mapped to the @map fields above.

  fingerprint    SecurityFingerprint? @relation("AssetFingerprint", fields: [fingerprintId], references: [id])
  publishedVideo PublishedVideo?      @relation("AssetPublishedVideo")

  @@unique([ownerType, ownerId, type])
  @@index([projectId])
  @@index([ownerType, ownerId])
  @@index([shotId])
  @@map("assets")
}

model TextSafetyResult {
  id              String             @id @default(uuid())
  resourceType    String
  resourceId      String
  decision        TextSafetyDecision
  riskLevel       RiskLevel
  flags           Json?              @default("[]")
  reasons         Json?              @default("[]")
  sanitizedDigest String?
  traceId         String?
  createdAt       DateTime?          @default(now())

  @@index([decision, createdAt(sort: Desc)], map: "text_safety_results_decision_createdat_idx")
  @@index([resourceType, resourceId], map: "text_safety_results_resourcetype_resourceid_idx")
  @@index([riskLevel, createdAt(sort: Desc)], map: "text_safety_results_risklevel_createdat_idx")
  @@map("text_safety_results")
}

model CostLedger {
  id              String        @id @default(uuid())
  userId          String?
  projectId       String
  jobId           String
  jobType         String
  engineKey       String?
  attempt         Int           @default(0)
  costAmount      Float         @default(0.0)
  currency        String        @default("USD")
  billingUnit     String?
  quantity        Float         @default(0.0)
  metadata        Json?
  createdAt       DateTime      @default(now()) @map("created_at")
  traceId         String?
  orgId           String?
  totalCost       Float?
  costType        String?
  unitCost        Float?
  modelName       String?
  totalCredits    Float?
  unitCostCredits Float?
  timestamp       DateTime      @default(now())
  billingStatus   BillingStatus @default(PENDING) @map("billing_status")
  billingEventId  String?       @map("billing_event_id")
  billedAt        DateTime?     @map("billed_at")
