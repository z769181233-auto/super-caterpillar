// ============================================
// Studio: 小说导入体系 (Novel Import System)
// ============================================

model NovelSource {
  id             String   @id @default(uuid())
  projectId      String
  novelTitle     String? // 作品名（从文件名或元数据提取）
  novelAuthor    String? // 作者（从文件内容或元数据提取）
  rawText        String   @db.Text // 完整原始文本（UTF-8）
  filePath       String? // 文件存储路径
  fileName       String? // 原始文件名
  fileSize       Int? // 文件大小（字节）
  fileType       String? // 文件类型：txt, docx, epub, md
  characterCount Int? // 字符数
  chapterCount   Int? // 章节数
  metadata       Json? // 额外元数据（如 EPUB 的 metadata，编码信息等）
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  project      Project            @relation("ProjectNovelSources", fields: [projectId], references: [id], onDelete: Cascade)
  analysisJobs NovelAnalysisJob[] @relation("NovelSourceAnalysisJobs")
  chapters     NovelChapter[]     @relation("NovelSourceChapters")

  @@index([projectId])
  @@map("novel_sources")
}

model NovelChapter {
  id             String   @id @default(uuid())
  novelSourceId  String
  orderIndex     Int // 章节顺序（从1开始）
  title          String // 章节标题
  rawText        String   @db.Text // 章节原始文本（UTF-8）
  summary        String?  @db.Text // S1-FIX-A: 引擎对章节的摘要，后续由小说分析引擎生成
  startParagraph Int? // 起始段落索引（在原始文本中的位置）
  endParagraph   Int? // 结束段落索引
  characterCount Int? // 章节字符数
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  novelSource NovelSource  @relation("NovelSourceChapters", fields: [novelSourceId], references: [id], onDelete: Cascade)
  sceneDrafts SceneDraft[] @relation("ChapterSceneDrafts")
  episode     Episode?     @relation("ChapterEpisode") // 关联到 Episode（1章=1集）

  @@unique([novelSourceId, orderIndex])
  @@index([novelSourceId])
  @@map("novel_chapters")
}

model SceneDraft {
  id             String           @id @default(uuid())
  chapterId      String
  orderIndex     Int // 场景顺序（从1开始）
  title          String? // 场景标题
  summary        String?          @db.Text // 场景摘要（50-80字）
  characters     Json? // 涉及角色列表 [{ name, role }]
  location       String? // 地点
  emotions       Json? // 情绪标签 [{ emotion, intensity }]
  rawTextRange   Json? // 原文范围 { startParagraph, endParagraph }
  status         SceneDraftStatus @default(DRAFT) // DRAFT / ANALYZED / FINALIZED
  analysisResult Json? // LLM分析结果（JSON格式）
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relations
  chapter NovelChapter @relation("ChapterSceneDrafts", fields: [chapterId], references: [id], onDelete: Cascade)
  scene   Scene?       @relation("SceneDraftScene") // 关联到最终 Scene

  @@unique([chapterId, orderIndex])
  @@index([chapterId])
  @@index([status])
  @@map("scene_drafts")
}

enum SceneDraftStatus {
  DRAFT // 草稿（初始生成）
  ANALYZED // 已分析（LLM分析完成）
  FINALIZED // 已确认（用户确认后转为Scene）

  @@map("scene_draft_status")
}

model NovelAnalysisJob {
  id            String               @id @default(uuid())
  projectId     String
  novelSourceId String?
  chapterId     String? // 如果分析单章，指定章节ID
  jobType       NovelAnalysisJobType @default(ANALYZE_ALL) // 分析类型：全书或单章
  status        NovelAnalysisStatus  @default(PENDING)
  errorMessage  String?              @db.Text
  progress      Json? // 进度信息 { current, total, message }
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  // Relations
  project     Project?     @relation("ProjectNovelAnalysisJobs", fields: [projectId], references: [id], onDelete: Cascade)
  novelSource NovelSource? @relation("NovelSourceAnalysisJobs", fields: [novelSourceId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([novelSourceId])
  @@index([chapterId])
  @@index([status])
  @@map("novel_analysis_jobs")
}

enum NovelAnalysisJobType {
  ANALYZE_ALL // 分析全书
  ANALYZE_CHAPTER // 分析单章

  @@map("novel_analysis_job_type")
}

enum NovelAnalysisStatus {
  PENDING
  RUNNING
  DONE
  FAILED

  @@map("novel_analysis_status")
}

// ============================================
// API Key 安全体系 (API Key Security System)
// ============================================

// API Key 模型（用于机器/Worker/外部服务认证）
// 支持 HMAC + Nonce + Timestamp 签名机制
model ApiKey {
  id            String       @id @default(uuid())
  key           String       @unique // 公钥 ID（对外暴露，例如：ak_xxx）
  secretHash    String? // 密钥哈希（旧字段，仅用于 fallback，新创建的 key 不使用）
  // CE10 v2: AES-256-GCM 加密存储
  secretEnc     String? // 加密后的 secret（base64）
  secretEncIv   String? // GCM IV（base64）
  secretEncTag  String? // GCM 认证标签（base64）
  secretVersion Int?         @default(1) // 密钥版本（便于轮换）
  name          String? // 可选的 API Key 名称（便于管理）
  ownerUserId   String? // 可选，关联用户
  ownerOrgId    String? // 可选，关联组织
  status        ApiKeyStatus @default(ACTIVE) // 状态：ACTIVE / DISABLED
  lastUsedAt    DateTime? // 最后使用时间
  expiresAt     DateTime? // 过期时间（可选）
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Relations
  ownerUser User?         @relation("UserApiKeys", fields: [ownerUserId], references: [id])
  ownerOrg  Organization? @relation("OrganizationApiKeys", fields: [ownerOrgId], references: [id])
  auditLogs AuditLog[]    @relation("ApiKeyAuditLogs") // 审计日志关联

  @@index([key])
  @@index([status])
  @@index([ownerUserId])
  @@index([ownerOrgId])
  @@map("api_keys")
}

enum ApiKeyStatus {
  ACTIVE
  DISABLED

  @@map("api_key_status")
}

// ============================================
// 审计日志体系 (Audit Log System)
// ============================================

// 审计日志模型（用于记录关键操作）
// 支持 JWT 用户和 API Key 两种认证来源
model AuditLog {
  id           String    @id @default(uuid())
  userId       String? // JWT 用户 ID，可为空
  orgId        String? // 组织 ID (Stage 10)
  apiKeyId     String? // 对应 ApiKey.id，可为空（HMAC 调用场景）
  action       String // 动作标识：PROJECT_CREATED / TASK_CREATED / JOB_SUCCEEDED 等
  resourceType String // 资源类型：project / episode / scene / shot / task / job / worker / auth 等
  resourceId   String? // 资源主键 ID，可为空
  ip           String? // 请求 IP
  userAgent    String?   @db.Text // UA 字符串
  // V1.1: 记录签名相关字段
  nonce        String?
  signature    String?
  timestamp    DateTime?
  details      Json? // 附加信息（请求参数、结果摘要等）
  payload      Json? // S1-FIX-A: 规范向 payload：包含 action/resourceType/resourceId/ip/ua/nonce/signature/timestamp/details 等的完整快照
  createdAt    DateTime  @default(now())

  // Relations
  user         User?         @relation("UserAuditLogs", fields: [userId], references: [id])
  organization Organization? @relation("OrganizationAuditLogs", fields: [orgId], references: [id])
  apiKey       ApiKey?       @relation("ApiKeyAuditLogs", fields: [apiKeyId], references: [id])

  @@index([createdAt])
  @@index([action])
  @@index([resourceType, resourceId])
  @@index([userId])
  @@index([apiKeyId])
  @@index([nonce, timestamp])
  @@map("audit_logs")
}

