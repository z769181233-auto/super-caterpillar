  updatedAt     DateTime @updatedAt @map("updated_at")

  project     Project        @relation("ProjectNovelVolumes", fields: [projectId], references: [id], onDelete: Cascade)
  novelSource NovelSource    @relation("NovelSourceVolumes", fields: [novelSourceId], references: [id], onDelete: Cascade)
