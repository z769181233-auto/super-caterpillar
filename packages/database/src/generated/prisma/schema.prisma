model NovelChapter {
  id                 String   @id @default(uuid())
  volumeId           String   @map("volume_id")
  novelSourceId      String   @map("novel_source_id")
  index              Int
  title              String?
  summary            String?  @db.Text
  isSystemControlled Boolean  @default(false) @map("is_system_controlled")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // V3.0 增量对齐 P0-2: 向量检索能力
  summaryVector Unsupported("vector")? @map("summary_vector")

  volume      NovelVolume  @relation("VolumeChapters", fields: [volumeId], references: [id], onDelete: Cascade)
  novelSource NovelSource  @relation("NovelSourceChapters", fields: [novelSourceId], references: [id], onDelete: Cascade)
  scenes      NovelScene[] @relation("ChapterNovelScenes")
  episode     Episode?     @relation("ChapterEpisode")
  sceneDrafts SceneDraft[] @relation("ChapterSceneDrafts")

  @@unique([volumeId, index])
  @@map("novel_chapters")
}

model NovelScene {
  id                 String   @id @default(uuid())
  chapterId          String   @map("chapter_id")
  index              Int
  title              String?
  rawText            String?  @map("raw_text") @db.Text
  enrichedText       String?  @map("enriched_text") @db.Text
  visualDensityScore Float?   @map("visual_density_score")
  characterIds       Json?    @map("character_ids")
  directingNotes     String?  @map("directing_notes") @db.Text
  shotType           String?  @default("MEDIUM_SHOT") @map("shot_type")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // V3.0 Alignment
  projectId          String? @map("project_id")
  graphStateSnapshot Json?   @map("graph_state_snapshot")

  // V3.0 Bible Alignment
  locationSlug    String?  @map("location_slug")
  timeOfDay       String?  @map("time_of_day")
  environmentTags String[] @map("environment_tags")

  chapter NovelChapter @relation("ChapterNovelScenes", fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, index])
  @@map("novel_scenes")
}

