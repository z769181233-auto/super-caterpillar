// Prisma Schema for 毛毛虫宇宙 (Super Caterpillar Universe)
// Based on PLAN - STEP 2: Prisma Schema 顶层结构规划

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 用户体系 (User System)
// ============================================

model User {
  id                    String   @id @default(uuid())
  email                 String   @unique
  passwordHash          String
  avatar                String?
  userType              UserType @default(individual)
  role                  UserRole @default(VIEWER)
  tier                  UserTier @default(Free)
  quota                 Json? // { remainingTokens, computeSeconds, credits }
  defaultOrganizationId String? // Studio v0.7: 默认组织 ID
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  memberships         Membership[]         @relation("UserMemberships")
  ownedProjects       Project[]            @relation("ProjectOwner")
  ownedOrganizations  Organization[]       @relation("OrganizationOwner")
  billingEvents       BillingEvent[]       @relation("BillingEventUser")
  reviewLogs          PublishingReview[]   @relation("ReviewerUser")
  organizationMembers OrganizationMember[] @relation("UserOrganizationMember") // Studio v0.7
  apiKeys             ApiKey[]             @relation("UserApiKeys") // API Key 关联
  auditLogs           AuditLog[]           @relation("UserAuditLogs") // 审计日志关联
  subscriptions       Subscription[]       @relation("UserSubscription")

  @@map("users")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  slug      String?  @unique // Studio v0.7: 可选，用于 URL 或内部标识
  type      String? // Studio v0.7: 组织类型 (PERSONAL | TEAM)
  credits   Float    @default(0) // Stage 10: Organization Credits
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  owner         User                 @relation("OrganizationOwner", fields: [ownerId], references: [id])
  memberships   Membership[]         @relation("OrganizationMemberships")
  members       OrganizationMember[] @relation("OrganizationMembers") // Studio v0.7
  projects      Project[]            @relation("OrganizationProjects")
  shots         Shot[]               @relation("OrganizationShots") // Studio v0.7
  shotJobs      ShotJob[]            @relation("OrganizationShotJobs") // Studio v0.7
  tasks         Task[]               @relation("OrganizationTasks") // Studio v0.8: 平台任务
  costCenters   CostCenter[]         @relation("OrganizationCostCenters")
  apiKeys       ApiKey[]             @relation("OrganizationApiKeys") // API Key 关联
  billingEvents BillingEvent[]       @relation("BillingEventOrganization")
  auditLogs     AuditLog[]           @relation("OrganizationAuditLogs")
  subscriptions Subscription[]       @relation("OrganizationSubscription")

  @@unique([ownerId, type])
  @@map("organizations")
}

model Membership {
  id             String         @id @default(uuid())
  userId         String
  organizationId String
  role           MembershipRole
  permissions    Json? // { projectPermissions: { projectId: [read, write, generate, publish, manage] } }
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  user         User         @relation("UserMemberships", fields: [userId], references: [id])
  organization Organization @relation("OrganizationMemberships", fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@map("memberships")
}

// ============================================
// 项目体系 (Project System - 五层内容结构)
// ============================================

model Project {
  id             String        @id @default(uuid())
  name           String
  description    String?
  ownerId        String
  organizationId String // Studio v0.7: 所属组织（必填，不再可选）
  status         ProjectStatus @default(in_progress)
  metadata       Json? // { timeline, progress, settings } (保留用于兼容)
  settingsJson   Json? // DBSpec V1.1: 项目级配置 JSON (settings_json)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  owner                  User                    @relation("ProjectOwner", fields: [ownerId], references: [id])
  organization           Organization            @relation("OrganizationProjects", fields: [organizationId], references: [id], onDelete: Restrict)
  seasons                Season[]                @relation("ProjectSeasons") // 影视工业标准：Project → Season → Episode
  episodes               Episode[]               @relation("ProjectEpisodes") // @deprecated 保留用于向下兼容
  billingEvents          BillingEvent[]          @relation("BillingEventProject")
  engineTasks            EngineTask[]            @relation("ProjectEngineTask")
  tasks                  Task[]                  @relation("ProjectTasks") // Studio v0.8: 平台任务
  novelSources           NovelSource[]           @relation("ProjectNovelSources") // Studio: 小说导入
  novelAnalysisJobs      NovelAnalysisJob[]      @relation("ProjectNovelAnalysisJobs") // Studio: 小说分析任务
  shotJobs               ShotJob[]               @relation("ProjectShotJobs") // ShotJob 关联
  projectMembers         ProjectMember[]
  structureQualityReport StructureQualityReport? @relation("ProjectQualityReport")
  novelParseResults      NovelParseResult[]      @relation("ProjectNovelParseResults")
  qualityMetrics         QualityMetrics[]        @relation("ProjectQualityMetrics")
  assets                 Asset[]                 @relation("ProjectAssets")

  @@map("projects")
}

// ============================================
// 影视工业标准层级：Season（季/部）
// @deprecated 根据 DBSpec V1.1，应使用四层结构（Project → Episode → Scene → Shot）
// 保留此模型用于向后兼容，新代码应直接使用 Project → Episode 关联
// ============================================

model Season {
  id          String   @id @default(uuid())
  projectId   String
  index       Int // 季序号（从 1 开始）
  title       String // 季标题
  description String?  @db.Text // 季描述
  metadata    Json?    @default("{}") // 额外元数据
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  project  Project   @relation("ProjectSeasons", fields: [projectId], references: [id], onDelete: Cascade)
  episodes Episode[] @relation("SeasonEpisodes")

  @@unique([projectId, index])
  @@index([projectId])
  @@map("seasons")
}

model Episode {
  id        String  @id @default(uuid())
  seasonId  String
  projectId String?
  index     Int
  name      String
  summary   String?
  chapterId String? @unique

  season            Season             @relation("SeasonEpisodes", fields: [seasonId], references: [id], onDelete: Cascade)
  project           Project?           @relation("ProjectEpisodes", fields: [projectId], references: [id], onDelete: Cascade)
  scenes            Scene[]            @relation("EpisodeScenes")
  shotJobs          ShotJob[]          @relation("EpisodeShotJobs")
  chapter           NovelChapter?      @relation("ChapterEpisode", fields: [chapterId], references: [id])
  publishingReviews PublishingReview[] @relation("EpisodePublishingReview")

  @@map("episodes")
}

model Scene {
  id                 String  @id @default(uuid())
  episodeId          String
  index              Int
  title              String
  summary            String?
  // V1.1: 角色 ID 列表（语义层面），存 JSON
  characters         Json?
  // V1.1: 视觉密度评分
  visualDensityScore Float?
  // V1.1: 文本增强结果
  enrichedText       String? @db.Text

  episode      Episode      @relation("EpisodeScenes", fields: [episodeId], references: [id], onDelete: Cascade)
  shots        Shot[]       @relation("SceneShots")
  shotJobs     ShotJob[]    @relation("SceneShotJobs")
  engineTasks  EngineTask[] @relation("SceneEngineTask")
  sceneDraft   SceneDraft?  @relation("SceneDraftScene", fields: [sceneDraftId], references: [id])
  sceneDraftId String?      @unique

  // 兼容项目级索引需求（Spec: scenes(project_id,index)）
  projectId String?

  @@index([projectId, index])
  @@map("scenes")
}

model Shot {
  id              String    @id @default(uuid())
  sceneId         String
  index           Int
  title           String?
  description     String?
  type            String
  params          Json      @default("{}")
  qualityScore    Json      @default("{}")
  reviewedAt      DateTime?
  durationSeconds Int?
  organizationId  String?
  // V1.1: 文本增强后的镜头 prompt
  enrichedPrompt  String?   @db.Text

  scene             Scene              @relation("SceneShots", fields: [sceneId], references: [id], onDelete: Cascade)
  organization      Organization?      @relation("OrganizationShots", fields: [organizationId], references: [id])
  engineTasks       EngineTask[]       @relation("ShotEngineTask")
  qualityScores     QualityScore[]     @relation("ShotQualityScore")
  safetyResults     SafetyResult[]     @relation("ShotSafetyResult")
  publishingReviews PublishingReview[] @relation("ShotPublishingReview")
  jobs              ShotJob[]          @relation("ShotJobs")
  shotPlanning      ShotPlanning?      @relation("ShotPlanning")
  assets            Asset[]            @relation("ShotAssets")

  @@index([sceneId, index])
  @@map("shots")
}

// ============================================
// Stage4: Semantic Enhancement / Shot Planning / Structure QA
// ============================================

model SemanticEnhancement {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nodeType      String
  nodeId        String
  data          Json
  engineKey     String
  engineVersion String?
  confidence    Float?

  @@unique([nodeType, nodeId])
  @@index([nodeType, nodeId])
  @@map("semantic_enhancements")
}

model ShotPlanning {
  id        String   @id @default(uuid())
  shotId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  data          Json
  engineKey     String
  engineVersion String?
  confidence    Float?

  shot Shot @relation("ShotPlanning", fields: [shotId], references: [id], onDelete: Cascade)

  @@map("shot_plannings")
}

model StructureQualityReport {
  id        String   @id @default(uuid())
  projectId String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  data          Json
  engineKey     String
  engineVersion String?

  project Project @relation("ProjectQualityReport", fields: [projectId], references: [id], onDelete: Cascade)

  @@map("structure_quality_reports")
}

// ============================================
// 引擎体系 (EngineHub System)
// ============================================

// 注意：EngineTask 保留用于向后兼容，新代码应使用 Task 模型
// EngineTask 主要用于引擎层面的任务记录（scene_parse, shot_plan 等）
model EngineTask {
  id            String           @id @default(uuid())
  type          EngineTaskType
  projectId     String
  sceneId       String?
  shotId        String?
  input         Json // EngineInput { text, projectId, episodeId, sceneId?, historyContext? }
  output        Json? // EngineOutput { sceneSummary?, shotPlan?, enrichData? }
  engineVersion String
  status        EngineTaskStatus @default(pending)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Relations
  project Project @relation("ProjectEngineTask", fields: [projectId], references: [id], onDelete: Cascade)
  scene   Scene?  @relation("SceneEngineTask", fields: [sceneId], references: [id], onDelete: Cascade)
  shot    Shot?   @relation("ShotEngineTask", fields: [shotId], references: [id], onDelete: Cascade)

  @@map("engine_tasks")
}

// S3-B.1: Engine 配置存储（数据库驱动）
// Stage3-A: 最小闭环字段（code, name, type, isActive, createdAt）
model Engine {
  id             String             @id @default(uuid())
  code           String             @unique // Stage3-A: 引擎代码（与 engineKey 保持一致）
  name           String // Stage3-A: 引擎名称（与 adapterName 保持一致）
  type           String // Stage3-A: 引擎类型（local | http | mock，与 adapterType 保持一致）
  isActive       Boolean            @default(true) // Stage3-A: 是否激活（与 enabled 保持一致）
  engineKey      String             @unique
  adapterName    String
  adapterType    String
  config         Json
  enabled        Boolean            @default(true)
  version        String?
  // S3-B.2: 引擎版本体系
  defaultVersion String?
  versions       EngineVersion[]
  jobBindings    JobEngineBinding[] @relation("EngineJobBindings")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@map("engines")
}

// S3-B.2: Engine 版本表
model EngineVersion {
  id            String   @id @default(uuid())
  engine        Engine   @relation(fields: [engineId], references: [id])
  engineId      String
  versionName   String
  config        Json
  enabled       Boolean  @default(true)
  rolloutWeight Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  jobBindings JobEngineBinding[] @relation("EngineVersionJobBindings")

  @@unique([engineId, versionName])
  @@map("engine_versions")
}

// Stage3-A: Job-Engine 逻辑绑定表
// 核心设计：Job 与 Engine 的逻辑绑定（不是物理绑定）
// - Worker 只消费"可执行 Job"，不直接知道 Engine 细节
// - Engine 失败/超时 = Job 级事件（通过 Job 状态机处理）
model JobEngineBinding {
  id              String                 @id @default(uuid())
  jobId           String                 @unique // 一个 Job 只能绑定一个 Engine
  engineId        String
  engineVersionId String? // 可选：绑定到特定版本
  engineKey       String // 冗余字段，便于查询
  status          JobEngineBindingStatus @default(BOUND)
  boundAt         DateTime               @default(now())
  executedAt      DateTime?
  completedAt     DateTime?
  errorMessage    String?
  metadata        Json? // 绑定时的元数据（策略、权重等）

  // Relations
  job           ShotJob        @relation("JobEngineBinding", fields: [jobId], references: [id], onDelete: Cascade)
  engine        Engine         @relation("EngineJobBindings", fields: [engineId], references: [id])
  engineVersion EngineVersion? @relation("EngineVersionJobBindings", fields: [engineVersionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([engineId, status])
  @@index([jobId])
  @@index([engineKey, status])
  @@map("job_engine_bindings")
}

/// Nonce 防重放存储（HMAC 安全）
model NonceStore {
  id        String    @id @default(uuid())
  nonce     String
  apiKey    String
  timestamp BigInt
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@unique([nonce, apiKey])
  @@map("nonce_store")
}

// RBAC 基础表
model Role {
  id        String           @id @default(uuid())
  name      String           @unique
  level     Int
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  members   ProjectMember[]
  rolePerms RolePermission[]

  @@map("roles")
}

model Permission {
  id        String           @id @default(uuid())
  key       String           @unique
  scope     String // system | project
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  rolePerms RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model ProjectMember {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  roleId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("project_members")
}

// 审计日志（Append-only）
model AuditLogLegacy {
  id           String   @id @default(uuid())
  userId       String?
  orgId        String?
  action       String
  resourceType String?
  resourceId   String?
  traceId      String
  ip           String?
  ua           String?
  timestamp    DateTime @default(now())
  details      Json?
  immutable    Boolean  @default(true)

  @@index([userId])
  @@index([resourceId])
  @@index([action])
  @@index([timestamp])
  @@map("audit_log")
  @@ignore
}

// ============================================
// 任务与调度体系 (TaskSystem & WorkerPool)
// ============================================

// Task（平台级任务）
// 定义：跨 Worker、跨重试、带业务语义的任务
// 职责：包含任务类型、业务对象关联、重试策略、优先级等平台级元信息
// 关系：Task → Job（一个 Task 可以产生多个 Job，用于重试）
model Task {
  id             String     @id @default(uuid())
  organizationId String
  projectId      String
  type           TaskType
  status         TaskStatus @default(PENDING)
  payload        Json?
  output         Json? // 任务输出结果，Engine/Worker 执行完成后写入
  attempts       Int        @default(0)
  maxRetry       Int        @default(3)
  retryCount     Int        @default(0)
  error          String?
  workerId       String? // 实际执行该 Task 的 Worker 节点 ID
  traceId        String? // Stage13-Final: Pipeline 级 traceId（用于 CE Core Layer 审计追溯）
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  jobs ShotJob[] @relation("TaskJobs")

  project      Project      @relation("ProjectTasks", fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization @relation("OrganizationTasks", fields: [organizationId], references: [id], onDelete: Restrict)
  worker       WorkerNode?  @relation("TaskWorker", fields: [workerId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
}

// WorkerJob（Worker 执行记录）
// 定义：Worker 维度的一次具体执行记录
// 职责：记录 Worker 执行任务的过程和结果
// 关系：WorkerJob 与 Task/Job 是不同层面的概念，WorkerJob 主要用于 Worker 内部调度和计费
model WorkerJob {
  id            String          @id @default(uuid())
  type          WorkerJobType
  payload       Json // { taskData, params, modelInfo }
  status        WorkerJobStatus @default(pending)
  workerId      String?
  retryCount    Int             @default(0)
  traceId       String
  jobId         String          @unique // BullMQ jobId
  engineVersion String?
  modelVersion  String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  worker        WorkerNode?    @relation("WorkerNodeJobs", fields: [workerId], references: [id])
  billingEvents BillingEvent[] @relation("BillingEventJob")

  @@map("worker_jobs")
}

// Job（Worker 执行单元）
// 定义：某个 Worker 在某个时间执行某个 Task 的一次尝试
// 职责：记录单次执行的状态、结果、错误信息等
// 关系：Job 属于某个 Task（taskId），一个 Task 可以产生多个 Job（用于重试）
// Studio v0.2: Shot 生成任务模型
// Studio v0.4: 增强队列化处理能力
// Studio v0.8: 引入 Task 层，Job 关联 Task
model ShotJob {
  id             String    @id @default(uuid())
  organizationId String
  projectId      String
  episodeId      String
  sceneId        String
  shotId         String
  taskId         String?
  workerId       String?
  status         JobStatus @default(PENDING)
  type           JobType
  priority       Int       @default(0)
  maxRetry       Int       @default(3)
  retryCount     Int       @default(0)
  attempts       Int       @default(0)
  payload        Json?
  engineConfig   Json?
  lastError      String?
  traceId        String? // Stage13: 用于 CE Core Layer 审计追溯
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  shot           Shot              @relation("ShotJobs", fields: [shotId], references: [id], onDelete: Cascade)
  task           Task?             @relation("TaskJobs", fields: [taskId], references: [id], onDelete: Cascade)
  worker         WorkerNode?       @relation("WorkerNodeShotJobs", fields: [workerId], references: [id], onDelete: SetNull)
  project        Project           @relation("ProjectShotJobs", fields: [projectId], references: [id], onDelete: Cascade)
  episode        Episode           @relation("EpisodeShotJobs", fields: [episodeId], references: [id], onDelete: Cascade)
  scene          Scene             @relation("SceneShotJobs", fields: [sceneId], references: [id], onDelete: Cascade)
  organization   Organization      @relation("OrganizationShotJobs", fields: [organizationId], references: [id], onDelete: Restrict)
  engineBinding  JobEngineBinding? @relation("JobEngineBinding")
  generatedAsset Asset[]           @relation("JobGeneratedAsset")
}

model WorkerNode {
  id            String       @id @default(uuid())
  workerId      String       @unique
  name          String? // Worker 名称（可选）
  status        WorkerStatus @default(offline)
  gpuCount      Int          @default(0)
  gpuMemory     Int          @default(0)
  gpuType       String       @default("unknown")
  tasksRunning  Int          @default(0)
  temperature   Float?
  capabilities  Json         @default("{}") // { supportedJobTypes[], supportedModels[], maxBatchSize }
  lastHeartbeat DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Relations
  jobs     WorkerJob[] @relation("WorkerNodeJobs")
  shotJobs ShotJob[]   @relation("WorkerNodeShotJobs") // Orchestrator Stage2: 关联 ShotJob
  tasks    Task[]      @relation("TaskWorker") // S1-FIX-A: Task 关联 Worker

  @@index([status])
  @@map("worker_nodes")
}

// Stage2-A: Worker 心跳记录
model WorkerHeartbeat {
  workerId   String   @id @map("worker_id")
  lastSeenAt DateTime @map("last_seen_at")
  status     String   @default("ALIVE") // ALIVE | DEAD
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([status, lastSeenAt])
  @@map("worker_heartbeats")
}

// ============================================
// 模型宇宙体系 (Model Universe System)
// ============================================

model ModelRegistry {
  id                 String    @id @default(uuid())
  name               String
  type               ModelType
  version            String
  changelog          String?
  compatibleEngines  Json // { engines: [CE01, CE02, ...] }
  performanceMetrics Json? // { latency, accuracy, cost }
  fineTuneInfo       Json? // { method, dataset, params }
  seed               String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([name, version])
  @@map("model_registry")
}

model TemplatePreset {
  id        String       @id @default(uuid())
  type      TemplateType
  name      String
  preset    Json // 根据类型不同，包含 pose 参数、camera 参数、style 参数
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("template_presets")
}

// ============================================
// 质量与安全体系 (Quality & Safety System)
// ============================================

model QualityScore {
  id                 String   @id @default(uuid())
  shotId             String
  visualDensityScore Float
  consistencyScore   Float
  motionScore        Float
  clarityScore       Float
  aestheticScore     Float
  overallScore       Float
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  shot Shot @relation("ShotQualityScore", fields: [shotId], references: [id])

  @@map("quality_scores")
}

model SafetyResult {
  id           String       @id @default(uuid())
  shotId       String
  textScore    Float
  imageScore   Float
  riskLevel    RiskLevel
  reviewStatus ReviewStatus @default(require_human_review)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  shot Shot @relation("ShotSafetyResult", fields: [shotId], references: [id])

  @@map("safety_results")
}

// ============================================
// 商业化体系 (Billing System)
// ============================================

model BillingEvent {
  id                 String           @id @default(uuid())
  eventType          BillingEventType
  userId             String
  organizationId     String?
  projectId          String?
  jobId              String?
  amount             Float
  creditsConsumed    Float
  computeSecondsUsed Float
  gpuCost            Float
  modelCost          Float
  storageCost        Float
  totalCost          Float
  billingStatus      BillingStatus    @default(pending)
  invoiceId          String?
  metadata           Json? // Stage 10: TraceId, JobType, etc.
  timestamp          DateTime         @default(now())

  // Relations
  user         User          @relation("BillingEventUser", fields: [userId], references: [id])
  organization Organization? @relation("BillingEventOrganization", fields: [organizationId], references: [id])
  project      Project?      @relation("BillingEventProject", fields: [projectId], references: [id])
  job          WorkerJob?    @relation("BillingEventJob", fields: [jobId], references: [id])

  @@map("billing_events")
}

model CostCenter {
  id             String   @id @default(uuid())
