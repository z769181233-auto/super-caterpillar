{
  "version": "1.0.0",
  "required_dirs": [
    "docs/_specs",
    "docs/_specs/governance",
    "docs/_evidence",
    "tools/gate/gates"
  ],
  "required_files": [
    "docs/_specs/governance/ENGINEERING_GOVERNANCE_POST_SEALED.md",
    "docs/_specs/governance/gov_post_sealed.config.json",
    "tools/gate/gates/gate-post_sealed_governance.sh",
    "tools/gate/gates/gate-audit_repo_structure_redline.sh",
    {
      "name": "SHELL_SAFETY",
      "script": "tools/gate/gates/gate-audit_shell_safety_redline.sh"
    },
    {
      "name": "PATH_HYGIENE",
      "script": "tools/gate/gates/gate-audit_path_hygiene_redline.sh"
    },
    {
      "name": "SQL_INJECTION",
      "script": "tools/gate/gates/gate-audit_psql_dq_redline.sh"
    }
  ],
  "evidence": {
    "root": "docs/_evidence",
    "run_dir_prefix": "post_sealed_governance",
    "dir_regex": "^[a-zA-Z0-9]+(_[a-zA-Z0-9]+)*_([0-9]{8}_[0-9]{6}|[0-9]{14})$",
    "required_artifacts": [
      "RUN_LOG.txt",
      "SUMMARY.json",
      "EVIDENCE_INDEX.json"
    ]
  },
  "gate_shell": {
    "glob": "tools/gate/gates/*.sh",
    "required_shebang": "#!/usr/bin/env bash",
    "required_contains": [
      "set -euo pipefail",
      "IFS=$'\\n\\t'"
    ],
    "forbidden_regex": [
      "\\beval\\b",
      "`",
      "source\\s*<\\(",
      "curl\\s+[^|]+\\|\\s*(bash|sh)"
    ]
  },
  "psql_dq": {
    "tag": "gate",
    "require_tagged_dq_if_psql_c_has_vars": true,
    "psql_command_regex": "\\bpsql\\b",
    "c_flag_regex": "(^|\\s)-c(\\s|$)"
  }
}