/// Day-3+: 千万字级分块模型（支持 1500万字小说断点恢复）
/// 用于将超大型小说切分为可处理的小块（≤6k tokens）
model NovelChunk {
  id            String   @id @default(uuid())
  novelSourceId String
  orderIndex    Int      /// 块序号，用于排序和重组
  rawText       String   @db.Text /// PostgreSQL Text 类型，支持无限长度
  hash          String   /// SHA256 hash for deduplication and integrity
  status        String   @default("PENDING") /// PENDING / PARSED / FAILED
  charCount     Int      @default(0) /// 字符数统计
  tokenEstimate Int      @default(0) /// Token 估算值（用于计费和容量规划）
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([novelSourceId, orderIndex])
  @@index([novelSourceId])
  @@map("novel_chunks")
}

/// Day-3: DAG 状态追踪模型
/// 追踪每个 chunk 在 CE06/CE03/CE04 pipeline 中的执行状态
model ParseBlock {
  id            String   @id @default(uuid())
  novelSourceId String
  chunkId       String
  blockType     String   /// CE06 / CE03 / CE04
  status        String   @default("PENDING") /// PENDING / RUNNING / DONE / FAILED
  resultRef     String?  /// Reference to result (e.g., jobId or output location)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([chunkId, blockType])
  @@index([novelSourceId])
  @@index([chunkId])
  @@map("parse_blocks")
}

