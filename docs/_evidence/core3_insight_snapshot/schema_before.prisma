  @@index([jobId])
  @@map("credit_ledgers")
}

enum BudgetWindow {
  DAILY
  MONTHLY
}

model Budget {
  id           String       @id @default(uuid())
  targetId     String // projectId
  targetType   OwnerType
  window       BudgetWindow @default(DAILY)
  limitCredits Decimal      @db.Decimal(20, 6)
  action       BudgetAction
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([targetId, window])
  @@index([targetId, targetType])
  @@map("budgets")
}

model BudgetWindowState {
  id              String       @id @default(uuid())
  targetId        String // projectId
  window          BudgetWindow
  windowStart     DateTime // 当天 00:00 或当月 1 号 00:00
  reservedCredits Decimal      @default(0) @db.Decimal(20, 6)
  spentCredits    Decimal      @default(0) @db.Decimal(20, 6)
  updatedAt       DateTime     @updatedAt

  @@unique([targetId, window, windowStart])
  @@index([targetId, window])
  @@map("budget_window_states")
}

enum OwnerType {
  ORGANIZATION
  PROJECT
  USER

  @@map("owner_type")
}

enum CreditAction {
  REFILL
  RESERVE
  SETTLE
  RELEASE
  REFUND
  GRANT

  @@map("credit_action")
}

enum BudgetAction {
  WARN
  BLOCK

  @@map("budget_action")
}

// --- BILLING PRODUCT LAYER (Stage-10 P3-A) ---

model Plan {
  id        String        @id @default(uuid())
  code      String        @unique // e.g., 'FREE', 'PRO'
  name      String
  price     Decimal       @db.Decimal(10, 2)
  currency  String        @default("USD")
  isActive  Boolean       @default(true)
  quotas    PlanQuota[]
  projects  ProjectPlan[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("plans")
}

model PlanQuota {
  id         String       @id @default(uuid())
  planId     String
  limitType  String // e.g., 'DAILY_CREDITS', 'MONTHLY_CREDITS', 'CONCURRENCY'
  limitValue Decimal      @db.Decimal(20, 6)
  action     BudgetAction @default(BLOCK)
  plan       Plan         @relation(fields: [planId], references: [id])

  @@map("plan_quotas")
}

model ProjectPlan {
  id        String    @id @default(uuid())
  projectId String    @unique
  planId    String
  startedAt DateTime  @default(now())
  expiresAt DateTime?
  project   Project   @relation(fields: [projectId], references: [id])
  plan      Plan      @relation(fields: [planId], references: [id])

  @@map("project_plans")
}

model BillingStatement {
  id              String   @id @default(uuid())
  orgId           String
  projectId       String?
  periodStart     DateTime
  periodEnd       DateTime
  totalCost       Decimal  @db.Decimal(20, 6)
  creditsConsumed Decimal  @db.Decimal(20, 6)
  status          String // DRAFT, FINALIZED, PAID
  s3Url           String? // PDF link
  createdAt       DateTime @default(now())

  invoices Invoice[]

  @@index([orgId, periodStart])
  @@map("billing_statements")
}

model Invoice {
  id              String           @id @default(uuid())
  statementId     String
  amount          Decimal
  currency        String
  status          String // PENDING, PAID, FAILED
  paymentMethodId String?
  paidAt          DateTime?
  statement       BillingStatement @relation(fields: [statementId], references: [id])

  @@map("invoices")
}

model SettlementSnapshot {
  id         String   @id @default(uuid())
  jobId      String   @unique
  traceId    String
  capturedAt DateTime @default(now())
  ledgerData Json // 完整快照：CostLedger + CreditLedger entries

  @@map("settlement_snapshots")
}

// ===============================================
// CE03: Novel Analysis SSOT Models (Stage-17)
// Added for establishing Single Source of Truth
// Ensures idempotency via analysisKey + version control
// ===============================================

model NovelAnalysis {
  id              String                  @id @default(uuid())
  novelSourceId   String                  @map("novel_source_id")
  version         Int                     @default(1)
  analysisKey     String                  @unique @map("analysis_key") // sha256(novelSourceId + rawContentHash + modelUsed + schemaVersion + promptVersion)
  rawContentHash  String                  @map("raw_content_hash") // snapshot of rawText hash at analysis time
  modelUsed       String                  @map("model_used") // e.g. "gemini-1.5-pro"
  schemaVersion   Int                     @default(1) @map("schema_version")
  promptVersion   Int                     @default(1) @map("prompt_version")
  jobId           String?                 @map("job_id") // links to Job system
  status          String                  @default("PENDING") // PENDING / PROCESSING / COMPLETED / FAILED
  analysisResult  Json?                   @map("analysis_result") @db.JsonB
  errorDetails    Json?                   @map("error_details") @db.JsonB
  createdAt       DateTime                @default(now()) @map("created_at")
  completedAt     DateTime?               @map("completed_at")
  
  novelSource     NovelSource             @relation("NovelSourceAnalyses", fields: [novelSourceId], references: [id], onDelete: Cascade)
  chapters        AnalysisChapter[]       @relation("NovelAnalysisChapters")
  characters      AnalysisCharacter[]     @relation("NovelAnalysisCharacters")
  worldSetting    AnalysisWorldSetting?   @relation("NovelAnalysisWorldSetting")
  
  @@unique([novelSourceId, version])
  @@index([analysisKey])
  @@index([jobId])
  @@index([status])
  @@map("novel_analyses")
}

model AnalysisChapter {
  id              String          @id @default(uuid())
  analysisId      String          @map("analysis_id")
  chapterNumber   Int             @map("chapter_number")
  title           String?
  summary         String          @db.Text
  characters      String[]        // array of character names appearing in this chapter
  timeline        String?         // timeline identifier (e.g., "T1", "T2")
  emotionTone     String?         @map("emotion_tone") // emotional tone of the chapter
  createdAt       DateTime        @default(now()) @map("created_at")
  
  analysis        NovelAnalysis   @relation("NovelAnalysisChapters", fields: [analysisId], references: [id], onDelete: Cascade)
  
  @@unique([analysisId, chapterNumber])
  @@index([analysisId])
  @@map("analysis_chapters")
}

model AnalysisCharacter {
  id              String          @id @default(uuid())
  analysisId      String          @map("analysis_id")
  name            String
  traits          String[]        // character traits (e.g., ["brave", "cautious"])
  arc             String?         @db.Text // character arc description
  firstAppearance Int?            @map("first_appearance") // chapter number of first appearance
  createdAt       DateTime        @default(now()) @map("created_at")
  
  analysis        NovelAnalysis   @relation("NovelAnalysisCharacters", fields: [analysisId], references: [id], onDelete: Cascade)
  
  @@unique([analysisId, name])
  @@index([analysisId])
  @@map("analysis_characters")
}

model AnalysisWorldSetting {
  id          String          @id @default(uuid())
  analysisId  String          @unique @map("analysis_id")
  era         String?         // time period/era
  geography   String?         @db.Text // geographical setting
  rules       String[]        // world rules (e.g., magic system, tech level)
  createdAt   DateTime        @default(now()) @map("created_at")
  
  analysis    NovelAnalysis   @relation("NovelAnalysisWorldSetting", fields: [analysisId], references: [id], onDelete: Cascade)
  
  @@map("analysis_world_settings")
}
