generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id                    String               @id @default(uuid())
  email                 String               @unique
  passwordHash          String
  avatar                String?
  userType              UserType             @default(individual)
  role                  UserRole             @default(VIEWER)
  tier                  UserTier             @default(Free)
  quota                 Json?
  credits               Decimal              @default(0) @db.Decimal(20, 6)
  defaultOrganizationId String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  apiKeys               ApiKey[]             @relation("UserApiKeys")
  auditLogs             AuditLog[]           @relation("UserAuditLogs")
  billingEvents         BillingEvent[]       @relation("BillingEventUser")
  memberships           Membership[]         @relation("UserMemberships")
  organizationMembers   OrganizationMember[] @relation("UserOrganizationMember")
  ownedOrganizations    Organization[]       @relation("OrganizationOwner")
  ownedProjects         Project[]            @relation("ProjectOwner")
  reviewLogs            PublishingReview[]   @relation("ReviewerUser")
  subscriptions         Subscription[]       @relation("UserSubscription")
  billingRecords        BillingRecord[]      @relation("UserBillingRecords")

  @@map("users")
}

model Organization {
  id            String               @id @default(uuid())
  name          String
  ownerId       String
  slug          String?              @unique
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  credits       Float                @default(0)
  type          String?
  shotJobs      ShotJob[]            @relation("OrganizationShotJobs")
  tasks         Task[]               @relation("OrganizationTasks")
  apiKeys       ApiKey[]             @relation("OrganizationApiKeys")
  auditLogs     AuditLog[]           @relation("OrganizationAuditLogs")
  billingEvents BillingEvent[]       @relation("BillingEventOrganization")
  costCenters   CostCenter[]         @relation("OrganizationCostCenters")
  memberships   Membership[]         @relation("OrganizationMemberships")
  members       OrganizationMember[] @relation("OrganizationMembers")
  owner         User                 @relation("OrganizationOwner", fields: [ownerId], references: [id])
  projects      Project[]            @relation("OrganizationProjects")
  shots         Shot[]               @relation("OrganizationShots")
  subscriptions Subscription[]       @relation("OrganizationSubscription")

  @@unique([ownerId, type])
  @@map("organizations")
}

model Membership {
  id             String         @id @default(uuid())
  userId         String
  organizationId String
  role           MembershipRole
  permissions    Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation("OrganizationMemberships", fields: [organizationId], references: [id])
  user           User           @relation("UserMemberships", fields: [userId], references: [id])

  @@unique([userId, organizationId])
  @@map("memberships")
}

model Project {
  id                     String                  @id @default(uuid())
  name                   String
  description            String?
  ownerId                String
  organizationId         String
  status                 ProjectStatus           @default(in_progress)
  metadata               Json?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  settingsJson           Json?
  shotJobs               ShotJob[]               @relation("ProjectShotJobs")
  tasks                  Task[]                  @relation("ProjectTasks")
  assets                 Asset[]                 @relation("ProjectAssets")
  billingEvents          BillingEvent[]          @relation("BillingEventProject")
  engineTasks            EngineTask[]            @relation("ProjectEngineTask")
  episodes               Episode[]               @relation("ProjectEpisodes")
  novelAnalysisJobs      NovelAnalysisJob[]      @relation("ProjectNovelAnalysisJobs")
  novelParseResults      NovelParseResult?       @relation("ProjectNovelParseResults")
  novelSources           NovelSource[]           @relation("ProjectNovelSources")
  novelInsightSnapshots  NovelInsightSnapshot[]  @relation("ProjectNovelInsightSnapshots")
  projectMembers         ProjectMember[]
  organization           Organization            @relation("OrganizationProjects", fields: [organizationId], references: [id])
  owner                  User                    @relation("ProjectOwner", fields: [ownerId], references: [id])
  qualityMetrics         QualityMetrics[]        @relation("ProjectQualityMetrics")
  seasons                Season[]                @relation("ProjectSeasons")
  structureQualityReport StructureQualityReport? @relation("ProjectQualityReport")
  plan                   ProjectPlan?

  @@map("projects")
}

model Season {
  id          String    @id @default(uuid())
  projectId   String
  index       Int
  title       String
  description String?
  metadata    Json?     @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  episodes    Episode[] @relation("SeasonEpisodes")
  project     Project   @relation("ProjectSeasons", fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, index])
  @@index([projectId])
  @@map("seasons")
}

model Episode {
  id                String             @id @default(uuid())
  seasonId          String
  projectId         String?
  index             Int
  name              String
  summary           String?
  chapterId         String?            @unique
  shotJobs          ShotJob[]          @relation("EpisodeShotJobs")
  chapter           NovelChapter?      @relation("ChapterEpisode", fields: [chapterId], references: [id])
  project           Project?           @relation("ProjectEpisodes", fields: [projectId], references: [id], onDelete: Cascade)
  season            Season             @relation("SeasonEpisodes", fields: [seasonId], references: [id], onDelete: Cascade)
  publishingReviews PublishingReview[] @relation("EpisodePublishingReview")
  scenes            Scene[]            @relation("EpisodeScenes")

  @@map("episodes")
}

model Scene {
  id                 String       @id @default(uuid())
  episodeId          String
  index              Int
  title              String
  summary            String?
  sceneDraftId       String?      @unique
  characters         Json?
  enrichedText       String?
  projectId          String?
  visualDensityScore Float?
  shotJobs           ShotJob[]    @relation("SceneShotJobs")
  engineTasks        EngineTask[] @relation("SceneEngineTask")
  episode            Episode      @relation("EpisodeScenes", fields: [episodeId], references: [id], onDelete: Cascade)
  sceneDraft         SceneDraft?  @relation("SceneDraftScene", fields: [sceneDraftId], references: [id])
  shots              Shot[]       @relation("SceneShots")

  @@index([projectId, index])
  @@map("scenes")
}

model Shot {
  id                String             @id @default(uuid())
  sceneId           String
  index             Int
  title             String?
  description       String?
  type              String
  status            ShotStatus         @default(DRAFT)
  statusUpdatedAt   DateTime           @default(now())
  currentVariantId  String?
  params            Json               @default("{}")
  qualityScore      Json               @default("{}")
  reviewedAt        DateTime?
  durationSeconds   Int?
  organizationId    String?
  enrichedPrompt    String?
  identityLockToken String?            @map("identity_lock_token")
  jobs              ShotJob[]          @relation("ShotJobs")
  assets            Asset[]            @relation("ShotAssets")
  engineTasks       EngineTask[]       @relation("ShotEngineTask")
  publishingReviews PublishingReview[] @relation("ShotPublishingReview")
  qualityScores     QualityScore[]     @relation("ShotQualityScore")
  safetyResults     SafetyResult[]     @relation("ShotSafetyResult")
  shotPlanning      ShotPlanning?      @relation("ShotPlanning")
  organization      Organization?      @relation("OrganizationShots", fields: [organizationId], references: [id])
  scene             Scene              @relation("SceneShots", fields: [sceneId], references: [id], onDelete: Cascade)

  @@index([sceneId, index])
  @@map("shots")
}

model SemanticEnhancement {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  nodeType      String
  nodeId        String
  data          Json
  engineKey     String
  engineVersion String?
  confidence    Float?

  @@unique([nodeType, nodeId])
  @@index([nodeType, nodeId])
  @@map("semantic_enhancements")
}

model ShotPlanning {
  id            String   @id @default(uuid())
  shotId        String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  data          Json
  engineKey     String
  engineVersion String?
  confidence    Float?
  shot          Shot     @relation("ShotPlanning", fields: [shotId], references: [id], onDelete: Cascade)

  @@map("shot_plannings")
}

model StructureQualityReport {
  id            String   @id @default(uuid())
  projectId     String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  data          Json
  engineKey     String
  engineVersion String?
  project       Project  @relation("ProjectQualityReport", fields: [projectId], references: [id], onDelete: Cascade)

  @@map("structure_quality_reports")
}

model EngineTask {
  id            String           @id @default(uuid())
  type          EngineTaskType
  projectId     String
  sceneId       String?
  shotId        String?
  input         Json
  output        Json?
  engineVersion String
  status        EngineTaskStatus @default(pending)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  project       Project          @relation("ProjectEngineTask", fields: [projectId], references: [id], onDelete: Cascade)
  scene         Scene?           @relation("SceneEngineTask", fields: [sceneId], references: [id], onDelete: Cascade)
  shot          Shot?            @relation("ShotEngineTask", fields: [shotId], references: [id], onDelete: Cascade)

  @@map("engine_tasks")
}

model Engine {
  id             String             @id @default(uuid())
  engineKey      String             @unique
  adapterName    String
  adapterType    String
  config         Json
  enabled        Boolean            @default(true)
  version        String?
  defaultVersion String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  code           String             @unique
  isActive       Boolean            @default(true)
  name           String
  type           String
  versions       EngineVersion[]
  jobBindings    JobEngineBinding[] @relation("EngineJobBindings")

  @@map("engines")
}

model EngineVersion {
  id            String             @id @default(uuid())
  engineId      String
  versionName   String
  config        Json
  enabled       Boolean            @default(true)
  rolloutWeight Int?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  engine        Engine             @relation(fields: [engineId], references: [id])
  jobBindings   JobEngineBinding[] @relation("EngineVersionJobBindings")

  @@unique([engineId, versionName])
  @@map("engine_versions")
}

model JobEngineBinding {
  id              String                 @id @default(uuid())
  jobId           String                 @unique
  engineId        String
  engineVersionId String?
  engineKey       String
  status          JobEngineBindingStatus @default(BOUND)
  boundAt         DateTime               @default(now())
  executedAt      DateTime?
  completedAt     DateTime?
  errorMessage    String?
  metadata        Json?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  engine          Engine                 @relation("EngineJobBindings", fields: [engineId], references: [id])
  engineVersion   EngineVersion?         @relation("EngineVersionJobBindings", fields: [engineVersionId], references: [id])
  job             ShotJob                @relation("JobEngineBinding", fields: [jobId], references: [id], onDelete: Cascade)

  @@index([engineId, status])
  @@index([jobId])
  @@index([engineKey, status])
  @@map("job_engine_bindings")
}

/// Nonce 防重放存储（HMAC 安全）
model NonceStore {
  id        String    @id @default(uuid())
  nonce     String
  apiKey    String
  timestamp BigInt
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@unique([nonce, apiKey])
  @@map("nonce_store")
}

model Role {
  id        String           @id @default(uuid())
  name      String           @unique
  level     Int
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  members   ProjectMember[]
  rolePerms RolePermission[]

  @@map("roles")
}

model Permission {
  id        String           @id @default(uuid())
  key       String           @unique
  scope     String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  rolePerms RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model ProjectMember {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  roleId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("project_members")
}

model AuditLogLegacy {
  id           String   @id @default(uuid())
  userId       String?
  orgId        String?
  action       String
  resourceType String?
  resourceId   String?
  traceId      String
  ip           String?
  ua           String?
  timestamp    DateTime @default(now())
  details      Json?
  immutable    Boolean  @default(true)

  @@index([userId])
  @@index([resourceId])
  @@index([action])
  @@index([timestamp])
  @@map("audit_log")
  @@ignore
}

model Task {
  id             String       @id @default(uuid())
  organizationId String
  projectId      String
  type           TaskType
  status         TaskStatus   @default(PENDING)
  payload        Json?
  attempts       Int          @default(0)
  maxRetry       Int          @default(3)
  retryCount     Int          @default(0)
  error          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  output         Json?
  traceId        String?
  workerId       String?
  jobs           ShotJob[]    @relation("TaskJobs")
  organization   Organization @relation("OrganizationTasks", fields: [organizationId], references: [id])
  project        Project      @relation("ProjectTasks", fields: [projectId], references: [id], onDelete: Cascade)
  worker         WorkerNode?  @relation("TaskWorker", fields: [workerId], references: [id])

  @@index([status, createdAt])
}

model WorkerJob {
  id            String          @id @default(uuid())
  type          WorkerJobType
  payload       Json
  status        WorkerJobStatus @default(pending)
  workerId      String?
  retryCount    Int             @default(0)
  traceId       String
  jobId         String          @unique
  engineVersion String?
  modelVersion  String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  billingEvents BillingEvent[]  @relation("BillingEventJob")
  worker        WorkerNode?     @relation("WorkerNodeJobs", fields: [workerId], references: [id])

  @@map("worker_jobs")
}

model ShotJob {
  id             String            @id @default(uuid())
  organizationId String
  projectId      String
  episodeId      String
  sceneId        String
  shotId         String
  taskId         String?
  workerId       String?
  status         JobStatus         @default(PENDING)
  type           JobType
  priority       Int               @default(0)
  maxRetry       Int               @default(3)
  retryCount     Int               @default(0)
  attempts       Int               @default(0)
  payload        Json?
  engineConfig   Json?
  lastError      String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  traceId        String?
  engineKey      String?
  episode        Episode           @relation("EpisodeShotJobs", fields: [episodeId], references: [id], onDelete: Cascade)
  organization   Organization      @relation("OrganizationShotJobs", fields: [organizationId], references: [id])
  project        Project           @relation("ProjectShotJobs", fields: [projectId], references: [id], onDelete: Cascade)
  scene          Scene             @relation("SceneShotJobs", fields: [sceneId], references: [id], onDelete: Cascade)
  shot           Shot              @relation("ShotJobs", fields: [shotId], references: [id], onDelete: Cascade)
  task           Task?             @relation("TaskJobs", fields: [taskId], references: [id], onDelete: Cascade)
  worker         WorkerNode?       @relation("WorkerNodeShotJobs", fields: [workerId], references: [id])
  generatedAsset Asset[]           @relation("JobGeneratedAsset")
  engineBinding  JobEngineBinding? @relation("JobEngineBinding")

  @@index([status, createdAt])
  @@index([type, status])
  @@index([engineKey, status])
  @@map("shot_jobs")
}

model WorkerNode {
  id                String       @id @default(uuid())
  workerId          String       @unique
  name              String?
  status            WorkerStatus @default(offline)
  gpuCount          Int          @default(0)
  gpuMemory         Int          @default(0)
  gpuType           String       @default("unknown")
  tasksRunning      Int          @default(0)
  temperature       Float?
  capabilities      Json         @default("{}")
  supportedJobTypes String[]     @default([])
  lastHeartbeat     DateTime     @default(now())
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  shotJobs          ShotJob[]    @relation("WorkerNodeShotJobs")
  tasks             Task[]       @relation("TaskWorker")
  jobs              WorkerJob[]  @relation("WorkerNodeJobs")

  @@index([status])
  @@index([status, lastHeartbeat])
  @@map("worker_nodes")
}

model WorkerHeartbeat {
  workerId   String   @id @map("worker_id")
  lastSeenAt DateTime @map("last_seen_at")
  status     String   @default("ALIVE")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([status, lastSeenAt])
  @@map("worker_heartbeats")
}

model ModelRegistry {
  id                 String    @id @default(uuid())
  name               String
  type               ModelType
  version            String
  changelog          String?
  compatibleEngines  Json
  performanceMetrics Json?
  fineTuneInfo       Json?
  seed               String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([name, version])
  @@map("model_registry")
}

model TemplatePreset {
  id        String       @id @default(uuid())
  type      TemplateType
  name      String
  preset    Json
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("template_presets")
}

model QualityScore {
  id                 String   @id @default(uuid())
  shotId             String
  visualDensityScore Float
  consistencyScore   Float
  motionScore        Float
  clarityScore       Float
  aestheticScore     Float
  overallScore       Float
  calcVersion        Int      @default(1)
  weightsSnapshot    Json?
  thresholdSnapshot  Json?
  traceId            String?
  inputsSnapshotHash String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  shot               Shot     @relation("ShotQualityScore", fields: [shotId], references: [id])

  @@unique([shotId, calcVersion])
  @@map("quality_scores")
}

model SafetyResult {
  id                 String       @id @default(uuid())
  shotId             String
  textScore          Float
  imageScore         Float
  riskLevel          RiskLevel
  reviewStatus       ReviewStatus @default(require_human_review)
  version            Int          @default(1)
  reasons            Json?
  evidenceRef        String?
  traceId            String?
  inputsSnapshotHash String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  shot               Shot         @relation("ShotSafetyResult", fields: [shotId], references: [id])

  @@unique([shotId, version])
  @@map("safety_results")
}

model BillingEvent {
  id                 String           @id @default(uuid())
  eventType          BillingEventType
  userId             String
  organizationId     String?
  projectId          String?
  jobId              String?
  amount             Float
  creditsConsumed    Float
  computeSecondsUsed Float
  gpuCost            Float
  modelCost          Float
  storageCost        Float
  totalCost          Float
  billingStatus      BillingStatus    @default(pending)
  invoiceId          String?
  timestamp          DateTime         @default(now())
  metadata           Json?
  job                WorkerJob?       @relation("BillingEventJob", fields: [jobId], references: [id])
  organization       Organization?    @relation("BillingEventOrganization", fields: [organizationId], references: [id])
  project            Project?         @relation("BillingEventProject", fields: [projectId], references: [id])
  user               User             @relation("BillingEventUser", fields: [userId], references: [id])

  @@map("billing_events")
}

model CostCenter {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  budget         Float
  currentCost    Float        @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation("OrganizationCostCenters", fields: [organizationId], references: [id])

  @@map("cost_centers")
}

model Subscription {
  id                 String             @id @default(uuid())
  userId             String?
  organizationId     String?
  planId             String
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  organization       Organization?      @relation("OrganizationSubscription", fields: [organizationId], references: [id])
  user               User?              @relation("UserSubscription", fields: [userId], references: [id])

  @@index([userId])
  @@index([organizationId])
  @@map("subscriptions")
}

model PublishingReview {
  id                 String       @id @default(uuid())
  episodeId          String?
  shotId             String?
  reviewType         ReviewType
  reviewerId         String?
  result             ReviewResult
  reviewLog          Json
  decisionVersion    Int          @default(1)
  reasons            Json?
  traceId            String?
  inputsSnapshotHash String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  episode            Episode?     @relation("EpisodePublishingReview", fields: [episodeId], references: [id])
  reviewer           User?        @relation("ReviewerUser", fields: [reviewerId], references: [id])
  shot               Shot?        @relation("ShotPublishingReview", fields: [shotId], references: [id])

  @@unique([shotId, decisionVersion])
  @@map("publishing_reviews")
}

model OrganizationMember {
  id             String           @id @default(uuid())
  userId         String
  organizationId String
  role           OrganizationRole @default(VIEWER)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation("OrganizationMembers", fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation("UserOrganizationMember", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@map("organization_members")
}

model NovelSource {
  id              String             @id @default(uuid())
  projectId       String
  novelTitle      String?
  novelAuthor     String?
  rawText         String
  rawContentHash  String?            @db.VarChar(64) @map("raw_content_hash") // sha256 for deduplication
  filePath        String?
  fileName        String?
  fileSize        Int?
  fileType        String?
  characterCount  Int?
  chapterCount    Int?
  metadata        Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  analysisJobs    NovelAnalysisJob[] @relation("NovelSourceAnalysisJobs")
  chapters        NovelChapter[]     @relation("NovelSourceChapters")
  project         Project            @relation("ProjectNovelSources", fields: [projectId], references: [id], onDelete: Cascade)
  analyses        NovelAnalysis[]    @relation("NovelSourceAnalyses") // CE03 SSOT
  insightSnapshots NovelInsightSnapshot[] @relation("NovelSourceInsightSnapshots")

  @@index([projectId])
  @@index([rawContentHash])
  @@map("novel_sources")
}

model NovelChapter {
  id              String           @id @default(uuid())
  novelSourceId   String
  orderIndex      Int
  title           String
  rawText         String           @map("raw_text")
  startParagraph  Int?             @map("start_paragraph")
  endParagraph    Int?             @map("end_paragraph")
  characterCount  Int?             @map("character_count")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  summary         String?
  shortTermMemory MemoryShortTerm? @relation("ChapterShortTermMemory")
  episode         Episode?         @relation("ChapterEpisode")
  novelSource     NovelSource      @relation("NovelSourceChapters", fields: [novelSourceId], references: [id], onDelete: Cascade)
  sceneDrafts     SceneDraft[]     @relation("ChapterSceneDrafts")
  scenes          NovelScene[]     @relation("ChapterScenes")

  @@unique([novelSourceId, orderIndex])
  @@index([novelSourceId])
  @@map("novel_chapters")
}

model MemoryShortTerm {
  id                 String   @id @default(uuid())
  organizationId     String?  @map("organization_id")
  projectId          String?  @map("project_id")
  chapterId          String   @unique @map("chapter_id")
  summary            String?
  characterStateJson Json?    @map("character_state_json")
  keyEventsJson      Json?    @map("key_events_json")
  updatedAt          DateTime @updatedAt @map("updated_at")

  chapter NovelChapter @relation("ChapterShortTermMemory", fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@index([projectId, chapterId])
  @@index([updatedAt])
  @@map("memory_short_term")
}

model MemoryUpdateLog {
  id          String   @id @default(uuid())
  chapterId   String   @map("chapter_id")
  payloadHash String   @map("payload_hash")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([chapterId, payloadHash])
  @@index([chapterId])
  @@map("memory_update_logs")
}

model SceneDraft {
  id             String           @id @default(uuid())
  chapterId      String
  orderIndex     Int
  title          String?
  summary        String?
  characters     Json?
  location       String?
