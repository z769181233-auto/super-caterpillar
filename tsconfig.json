{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "baseUrl": ".",
    "paths": {
      "database": ["packages/database/src"],
      "@scu/shared-types": ["packages/shared-types/src"],
      "@scu/engines/*": ["packages/engines/*"],
      "@scu/api/*": ["apps/api/src/*"],
      "@scu/shared": ["packages/shared/index.ts"],
      "@scu/shared/*": ["packages/shared/*"]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node"
  },
  "include": ["tools/**/*", "apps/**/*", "packages/**/*"]
}
