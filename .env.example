# Super Caterpillar Universe - 环境变量示例
# 复制此文件为 .env.local 并填入实际值

# ============================================
# 必需变量（API/Worker 启动必需）
# ============================================

# 数据库连接（必需）
DATABASE_URL="postgresql://user:password@localhost:5432/super_caterpillar"

# JWT 密钥（必需，用于 API 认证）
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"

# ============================================
# 可选变量（有默认值）
# ============================================

# Node 环境
NODE_ENV="development"

# API 配置
API_PORT=3000
API_HOST="localhost"

# Redis（可选，默认 localhost:6379）
REDIS_URL="redis://localhost:6379"

# 前端 URL
FRONTEND_URL="http://localhost:3001"

# JWT 过期时间
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# 应用信息
APP_NAME="Super Caterpillar Universe"
APP_VERSION="1.0.0"

# 安全配置
BCRYPT_SALT_ROUNDS=10

# HMAC 认证配置
HMAC_TIMESTAMP_WINDOW=300000
HMAC_SIGNATURE_ALGORITHM="sha256"

# Worker 配置（可选）
WORKER_API_KEY=""
WORKER_API_SECRET=""
WORKER_ID="local-worker"
WORKER_NAME="local-worker"
WORKER_POLL_INTERVAL=2000

# 引擎配置
ENGINE_DEFAULT="mock"
ENGINE_REAL_HTTP_BASE_URL="http://localhost:8000"

# ============================================
# 存储路径配置（必需，用于 Worker 和 API 统一路径）
# ============================================

# 项目根目录路径（必需，用于计算存储路径）
# 示例：REPO_ROOT="/path/to/Super Caterpillar"
REPO_ROOT=""

# 存储根目录路径（可选，仅用于覆盖默认路径）
# 默认值：${REPO_ROOT}/.data/storage
# 仅在需要自定义存储位置时设置
# STORAGE_ROOT="/custom/storage/path"

# 存储调试日志（可选，仅开发环境）
# STORAGE_DEBUG="true"
