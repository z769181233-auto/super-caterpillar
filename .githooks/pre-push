#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

# === SINGLE ENTRYPOINT FOR PRE-PUSH GATES ===

echo "[HOOK] Starting Pre-push Verification Chain..."

# 1. Phase 3 & Governance Gates (Fast & Mandatory)
echo "------------------------------------------------"
echo "[G1] Governance & NLP Base..."
bash tools/gate/gates/gate-post_sealed_governance.sh
bash tools/gate/gates/gate-path-leak.sh
bash tools/gate/gates/gate_p3_nlp_base.sh
bash tools/gate/gates/gate_p3_ce_batch.sh

# 2. Main Branch Strict Enforcement
while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_ref" == "refs/heads/main" ]]; then
    echo "------------------------------------------------"
    echo "[G2] Main Branch Release Readiness (P6)..."
    export EVI_OVERRIDE="/tmp/p6_release_readiness_evidence"
    rm -rf "$EVI_OVERRIDE" || true
    bash tools/run_p6_release_readiness.sh
    
    # Verification of evidence
    test -f "$EVI_OVERRIDE/SHA256SUMS.txt"
    if command -v sha256sum >/dev/null 2>&1; then
      sha256sum -c "$EVI_OVERRIDE/SHA256SUMS.txt"
    else
      shasum -a 256 -c "$EVI_OVERRIDE/SHA256SUMS.txt"
    fi
  fi
done

# 3. Security Gates
echo "------------------------------------------------"
echo "[G3] Secret Scan (P9)..."
TMP_EVI="$(mktemp -d 2>/dev/null || mktemp -d -t p9_secret_scan)"
trap 'rm -rf "$TMP_EVI" || true' EXIT
bash tools/p9/gate_p9_1_secret_scan.sh "$TMP_EVI" >/dev/null

echo "------------------------------------------------"
echo "✅ PRE-PUSH SUCCESS: All gates passed."
