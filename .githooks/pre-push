#!/usr/bin/env bash
set -euo pipefail

while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_ref" == "refs/heads/main" ]]; then
    echo "[HOOK] enforcing P6 before push to main..."
    export EVI_OVERRIDE="/tmp/p6_release_readiness_evidence"
    rm -rf "$EVI_OVERRIDE" || true
    bash tools/run_p6_release_readiness.sh

    test -f "$EVI_OVERRIDE/SHA256SUMS.txt"
    test -f "$EVI_OVERRIDE/EVIDENCE_INDEX.json"
    test -f "$EVI_OVERRIDE/EVIDENCE_INDEX.sha256"

    if command -v sha256sum >/dev/null 2>&1; then
      sha256sum -c "$EVI_OVERRIDE/SHA256SUMS.txt"
      sha256sum -c "$EVI_OVERRIDE/EVIDENCE_INDEX.sha256"
    else
      shasum -a 256 -c "$EVI_OVERRIDE/SHA256SUMS.txt"
      shasum -a 256 -c "$EVI_OVERRIDE/EVIDENCE_INDEX.sha256"
    fi
    echo "[HOOK] P6 PASS. push allowed."
  fi
done


# --- P9-1 secret scan (HOOK-ENFORCED) ---
TMP_EVI="$(mktemp -d 2>/dev/null || mktemp -d -t p9_secret_scan)";
trap 'rm -rf "$TMP_EVI" || true' EXIT
bash tools/p9/gate_p9_1_secret_scan.sh "$TMP_EVI" >/dev/null
# ---------------------------------------
