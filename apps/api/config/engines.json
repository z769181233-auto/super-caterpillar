{
  "engines": [
    {
      "engineKey": "default_novel_analysis",
      "adapterName": "default_novel_analysis",
      "adapterType": "local",
      "isDefaultForJobTypes": {
        "NOVEL_ANALYSIS": true
      },
      "enabled": true
    },
    {
      "engineKey": "http_gemini_v1",
      "adapterName": "http",
      "adapterType": "http",
      "httpConfig": {
        "baseUrl": "https://api.gemini.com",
        "path": "/v1/invoke",
        "timeoutMs": 60000,
        "authMode": "bearer"
      },
      "modelInfo": {
        "modelName": "gemini-pro",
        "version": "v1.0"
      },
      "enabled": true
    },
    {
      "engineKey": "http_openai_gpt4",
      "adapterName": "http",
      "adapterType": "http",
      "httpConfig": {
        "baseUrl": "https://api.openai.com",
        "path": "/v1/chat/completions",
        "timeoutMs": 30000,
        "authMode": "bearer"
      },
      "modelInfo": {
        "modelName": "gpt-4",
        "version": "v1.0"
      },
      "enabled": true
    },
    {
      "engineKey": "http_local_llm",
      "adapterName": "http",
      "adapterType": "http",
      "httpConfig": {
        "baseUrl": "http://localhost:11434",
        "path": "/api/generate",
        "timeoutMs": 120000,
        "authMode": "none"
      },
      "modelInfo": {
        "modelName": "llama2",
        "version": "v1.0"
      },
      "enabled": true
    },
    {
      "engineKey": "http_mock_novel_analysis",
      "adapterName": "http",
      "adapterType": "http",
      "httpConfig": {
        "baseUrl": "http://localhost:19000",
        "path": "/invoke",
        "timeoutMs": 5000,
        "authMode": "none"
      },
      "modelInfo": {
        "modelName": "mock-novel-analysis",
        "version": "test"
      },
      "enabled": true
    },
    {
      "engineKey": "http_real_novel_analysis",
      "adapterName": "http",
      "adapterType": "http",
      "httpConfig": {
        "baseUrl": "https://your-real-http-engine.com",
        "path": "/invoke",
        "timeoutMs": 20000,
        "authMode": "bearer",
        "apiKey": "${HTTP_REAL_NA_API_KEY}"
      },
      "modelInfo": {
        "modelName": "real-na-v1",
        "version": "1.0.0"
      },
      "enabled": true
    },
    {
      "engineKey": "http_real_shot_render",
      "adapterName": "http",
      "adapterType": "http",
      "httpConfig": {
        "baseUrl": "https://your-real-http-engine.com",
        "path": "/invoke",
        "timeoutMs": 20000,
        "authMode": "bearer",
        "apiKey": "${HTTP_REAL_SR_API_KEY}"
      },
      "modelInfo": {
        "modelName": "real-shot-render-v1",
        "version": "1.0.0"
      },
      "enabled": true
    }
  ]
}
