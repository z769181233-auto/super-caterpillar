{
    "moduleFileExtensions": [
        "js",
        "json",
        "ts"
    ],
    "rootDir": ".",
    "testEnvironment": "node",
    "testRegex": ".e2e-spec.ts$",
    "testPathIgnorePatterns": [
        "/node_modules/",
        "hmac-security.e2e-spec.ts"
    ],
    "transform": {
        "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
        "^@scu/shared-types$": "<rootDir>/../../../packages/shared-types/src/index.ts",
        "^src/(.*)$": "<rootDir>/../src/$1",
        "^database$": "<rootDir>/../../../packages/database/src/index.ts"
    }
}