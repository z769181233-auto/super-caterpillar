{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "API_BASE_URL=http://localhost:3000 node -r tsconfig-paths/register dist/apps/api/src/main.js",
    "build": "tsc -p tsconfig.json && ln -sf apps/api/src/main.js dist/main.js",
    "start": "node -r tsconfig-paths/register dist/apps/api/src/main.js",
    "start:prod": "node -r tsconfig-paths/register dist/apps/api/src/main",
    "lint": "eslint \"{src,apps,libs}/**/*.ts\" --ignore-pattern \"src/scripts/**\" --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json --testPathPattern=e2e",
    "load:test": "ts-node scripts/load-test.ts",
    "e2e:novel-pipeline": "ts-node -r tsconfig-paths/register src/scripts/legacy/e2e-novel-pipeline.legacy.ts",
    "e2e:novel": "ts-node -r tsconfig-paths/register src/scripts/legacy/e2e-novel-pipeline.legacy.ts",
    "e2e:novel:worker": "ts-node -r tsconfig-paths/register src/scripts/e2e-novel-worker-pipeline.ts",
    "init:worker-api-key": "ts-node -r tsconfig-paths/register src/scripts/init-worker-api-key.ts",
    "delete:worker": "ts-node -r tsconfig-paths/register src/scripts/delete-worker.ts",
    "dev:create-test-novel-job": "ts-node -r tsconfig-paths/register src/scripts/dev-create-test-novel-job.ts",
    "create:test-novel-job": "ts-node -r tsconfig-paths/register src/scripts/create-test-novel-job.ts",
    "create:http-jobs": "ts-node -r tsconfig-paths/register src/scripts/create-novel-analysis-http-test-jobs.ts",
    "debug:jobs": "ts-node -r tsconfig-paths/register src/scripts/debug-jobs.ts",
    "reset:test-jobs": "ts-node -r tsconfig-paths/register src/scripts/reset-test-jobs.ts",
    "sync:engines": "ts-node -r tsconfig-paths/register src/scripts/sync-engines-from-json.ts",
    "init:ce-api-key": "ts-node -r tsconfig-paths/register ../../tools/smoke/init_ce_runtime_api_key.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.15",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.15",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.15",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "7.4.2",
    "@scu/config": "workspace:*",
    "@scu/engines-ce03": "workspace:*",
    "@scu/engines-ce04": "workspace:*",
    "@scu/engines-ce06": "workspace:^",
    "@scu/engines-ce08": "workspace:*",
    "@scu/engines-ce13": "workspace:*",
    "@scu/engines-scene-composition": "workspace:*",
    "@scu/engines-shot-render": "workspace:*",
    "@scu/engines-vg03": "workspace:*",
    "@scu/engines-vg04": "workspace:*",
    "@scu/engines-vg05": "workspace:*",
    "@scu/engines-video-merge": "workspace:^",
    "@scu/observability": "workspace:*",
    "@scu/shared": "workspace:*",
    "@scu/storage": "workspace:*",
    "@types/helmet": "^4.0.0",
    "@types/multer": "^2.0.0",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "chardet": "^2.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "database": "workspace:*",
    "epub2": "^3.0.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "iconv-lite": "^0.7.2",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.11.0",
    "multer": "^2.1.1",
    "nestjs-pino": "^4.6.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "replicate": "^1.4.0",
    "rxjs": "^7.8.2",
    "sharp": "0.34.5",
    "tsconfig-paths": "^4.2.0"
  },
  "prisma": {
    "schema": "../../packages/database/prisma/schema.prisma"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.15",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/iconv-lite": "^0.0.1",
    "@types/ioredis": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "@types/passport-jwt": "^4.0.1",
    "@types/redis": "^4.0.11",
    "@types/sharp": "^0.32.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@typescript-eslint/typescript-estree": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1",
      "^database$": "<rootDir>/../../../packages/database/src"
    }
  }
}
