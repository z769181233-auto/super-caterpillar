{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --ignore-pattern \"src/scripts/**\" --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json --testPathPattern=e2e",
    "load:test": "ts-node scripts/load-test.ts",
    "e2e:novel-pipeline": "ts-node -r tsconfig-paths/register src/scripts/legacy/e2e-novel-pipeline.legacy.ts",
    "e2e:novel": "ts-node -r tsconfig-paths/register src/scripts/legacy/e2e-novel-pipeline.legacy.ts",
    "e2e:novel:worker": "ts-node -r tsconfig-paths/register src/scripts/e2e-novel-worker-pipeline.ts",
    "init:worker-api-key": "ts-node -r tsconfig-paths/register src/scripts/init-worker-api-key.ts",
    "delete:worker": "ts-node -r tsconfig-paths/register src/scripts/delete-worker.ts",
    "dev:create-test-novel-job": "ts-node -r tsconfig-paths/register src/scripts/dev-create-test-novel-job.ts",
    "create:test-novel-job": "ts-node -r tsconfig-paths/register src/scripts/create-test-novel-job.ts",
    "create:http-jobs": "ts-node -r tsconfig-paths/register src/scripts/create-novel-analysis-http-test-jobs.ts",
    "debug:jobs": "ts-node -r tsconfig-paths/register src/scripts/debug-jobs.ts",
    "reset:test-jobs": "ts-node -r tsconfig-paths/register src/scripts/reset-test-jobs.ts",
    "sync:engines": "ts-node -r tsconfig-paths/register src/scripts/sync-engines-from-json.ts",
    "init:ce-api-key": "ts-node -r tsconfig-paths/register ../../tools/smoke/init_ce_runtime_api_key.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "5.22.0",
    "@scu/config": "workspace:*",
    "@scu/shared-types": "workspace:*",
    "@scu/storage": "workspace:^",
    "@types/helmet": "^4.0.0",
    "@types/multer": "^2.0.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "chardet": "^2.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cookie-parser": "^1.4.7",
    "database": "workspace:*",
    "epub2": "^3.0.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "iconv-lite": "^0.7.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.11.0",
    "multer": "^2.0.2",
    "nestjs-pino": "^4.5.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "redis": "^4.7.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "prisma": {
    "schema": "../../packages/database/prisma/schema.prisma"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.1",
    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "^10.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.25",
    "@types/iconv-lite": "^0.0.1",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/redis": "^4.0.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.0"
  }
}
