{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "pnpm -w --filter \"@scu/shared-types\" --filter database build && next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "lint:i18n": "node ../../scripts/i18n/no-hardcode-check.mjs",
    "lint:e2e-seal": "node scripts/e2e-seal-check.mjs",
    "lint:strict": "eslint \"src/components/**/*.{ts,tsx}\" ...",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@scu/shared-types": "workspace:*",
    "@tanstack/react-virtual": "^3.13.18",
    "database": "workspace:*",
    "next": "^14.0.4",
    "next-intl": "^4.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.71.1",
    "zod": "^4.3.5",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.0.4",
    "eslint-plugin-react-hooks": "^4.6.0",
    "playwright": "^1.58.2",
    "typescript": "^5.3.0"
  }
}
