{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "pnpm --filter \"@scu/shared-types\" --filter database build && next build",
    "start": "npx --yes serve@latest out -l tcp://0.0.0.0:${PORT:-3001}",
    "lint": "next lint",
    "lint:i18n": "node ../../scripts/i18n/no-hardcode-check.mjs",
    "lint:e2e-seal": "node scripts/e2e-seal-check.mjs",
    "lint:strict": "eslint \"src/components/**/*.{ts,tsx}\" ...",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@scu/shared-types": "workspace:*",
    "@tanstack/react-virtual": "^3.13.19",
    "database": "workspace:*",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-react-hooks": "^7.0.1",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3"
  }
}
