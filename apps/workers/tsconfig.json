{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "typeRoots": ["./node_modules/@types", "../../node_modules/@types", "./src/types"],
    "types": ["node"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "config": ["../../packages/config/src"],
      "@scu/config": ["../../packages/config/src"],
      "database": ["../../packages/database/src"],
      "@scu/shared-types": ["../../packages/shared-types/src"],
      "@scu/engines/*": ["../../packages/engines/*"],
      "@scu/engines-ce03": ["../../packages/engines-ce03/src"],
      "@scu/engines-ce04": ["../../packages/engines-ce04/src"],
      "@scu/storage": ["../../packages/storage/src"],
      "@scu/billing/*": ["../../packages/billing/*"],
      "@scu/observability": ["../../packages/observability/src"],
      "@scu/api/*": ["../../apps/api/src/*"]
    }
  },
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
