#!/bin/bash
# Git pre-push hook: master 分支推送前强制验证

set -e

# 检查是否推送到 master
while read local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/master" ]; then
    echo "🔍  检测到推送 master 分支，强制执行门禁验证..."
    echo ""
    
    # 强制运行门禁
    if ! ./tools/gate/merge_guard.sh; then
      echo ""
      echo "❌  门禁验证失败，拒绝推送 master"
      echo ""
      echo "请修复所有错误后重新推送"
      exit 1
    fi
    
    echo ""
    echo "✅  门禁验证通过，允许推送 master"
  fi
done

exit 0
