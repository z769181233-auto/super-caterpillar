#!/bin/bash
# Git pre-commit hook: 门禁验证 + 禁止在master直接commit

set -e

GATE_MARKER=".gate/last_ok"
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

# ========== 规则1: 禁止在master直接commit ==========
if [ "$CURRENT_BRANCH" = "master" ]; then
  # 检查是否有staged changes
  if ! git diff --cached --quiet; then
    echo "❌  禁止在 master 分支直接commit"
    echo ""
    echo "master 分支仅用于合并，不允许直接开发"
    echo ""
    echo "正确流程:"
    echo "  1. 创建 feature 分支: git checkout -b feature/xxx"
    echo "  2. 在 feature 分支开发并commit"
    echo "  3. 切回 master: git checkout master"
    echo "  4. 合并: git merge --no-ff feature/xxx"
    echo ""
    echo "⚠️  如果是灾难性紧急情况，请参考 docs/DEV_GATES.md Break-glass流程"
    exit 1
  fi
fi

# ========== 规则2: 门禁验证 ==========
# 检查门禁标记文件是否存在
if [ ! -f "$GATE_MARKER" ]; then
  echo "❌  未通过门禁验证，拒绝提交"
  echo ""
  echo "请先运行: pnpm gate:merge"
  exit 1
fi

# 读取标记文件中的状态
if command -v jq &> /dev/null; then
  MARKER_HEAD=$(cat "$GATE_MARKER" | jq -r '.head_sha')
  MARKER_INDEX=$(cat "$GATE_MARKER" | jq -r '.index_sha')
else
  MARKER_HEAD=$(grep '"head_sha"' "$GATE_MARKER" | cut -d'"' -f4)
  MARKER_INDEX=$(grep '"index_sha"' "$GATE_MARKER" | cut -d'"' -f4)
fi

# 获取当前状态
CURRENT_HEAD=$(git rev-parse HEAD)
CURRENT_INDEX=$(git write-tree)

# 检查 HEAD 是否一致
if [ "$MARKER_HEAD" != "$CURRENT_HEAD" ]; then
  echo "❌  HEAD 已变更，门禁标记失效"
  echo ""
  echo "请重新运行: pnpm gate:merge"
  exit 1
fi

# 检查 INDEX（暂存区）是否一致
if [ "$MARKER_INDEX" != "$CURRENT_INDEX" ] && [ "$MARKER_INDEX" != "UNKNOWN" ]; then
  echo "❌  暂存区已变更，门禁标记失效"
  echo ""
  echo "请重新运行: pnpm gate:merge"
  exit 1
fi

# 简化时间检查：使用文件修改时间
MARKER_MTIME=$(stat -f %m "$GATE_MARKER" 2>/dev/null || stat -c %Y "$GATE_MARKER" 2>/dev/null)
CURRENT_TIME=$(date +%s)
DIFF=$((CURRENT_TIME - MARKER_MTIME))

if [ $DIFF -gt 300 ]; then
  echo "⚠️  门禁标记已过期（超过5分钟）"
  echo ""
  echo "已过时间: ${DIFF}秒"
  echo "请重新运行: pnpm gate:merge"
  exit 1
fi

echo "✅  门禁验证通过"
echo "  - 分支: $CURRENT_BRANCH"
echo "  - HEAD: $CURRENT_HEAD ✓"
echo "  - INDEX: $CURRENT_INDEX ✓"
echo "  - 时效: ${DIFF}s / 300s ✓"
exit 0
