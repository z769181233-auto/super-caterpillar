{
  "name": "super-caterpillar-universe",
  "version": "1.0.0",
  "private": true,
  "description": "Super Caterpillar Universe — Monorepo (API / Web / Workers)",
  "pnpm": {
    "overrides": {
      "prisma": "5.22.0",
      "@prisma/client": "5.22.0",
      "next": "14.2.35",
      "qs": "6.14.1",
      "glob": "10.5.0"
    }
  },
  "scripts": {
    "env:init": "node tools/env/print-env-source.js",
    "preinstall": "npx only-allow pnpm",
    "env:check": "node tools/env/print-env-source.js",
    "db:up": "bash tools/db/up-postgres.sh && node tools/db/wait-postgres.js",
    "db:init": "pnpm db:up && node tools/db/init-db.js",
    "db:status": "docker ps -a --filter name=scu-postgres --format \"table {{.Names}}\\t{{.Status}}\\t{{.Ports}}\"",
    "dev": "pnpm env:init && turbo run dev --parallel --filter=api --filter=web --filter=@scu/worker",
    "dev:api": "pnpm -w --filter api dev",
    "dev:web": "pnpm -w --filter web dev",
    "dev:worker": "pnpm -w --filter @scu/worker dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:watch": "jest --watch",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "mock:http-engine": "ts-node apps/tools/mock-http-engine/server.ts",
    "postinstall": "pnpm --filter database prisma:generate",
    "preflight": "node tools/preflight.mjs",
    "test:contract": "pnpm -w --filter api test:e2e",
    "smoke": "node tools/smoke/run-smoke.mjs",
    "smoke:stage1-2": "tsx tools/smoke/stage1_stage2_smoke.ts",
    "smoke:diag:db": "pnpm -w exec tsx tools/smoke/diag_db.ts",
    "typecheck": "turbo run typecheck",
    "verify:cold-start": "pnpm -w exec tsx tools/verify_cold_start.ts",
    "verify:stage10": "pnpm -w exec tsx scripts/verify_stage10.ts",
    "verify:signed-url": "pnpm -w exec tsx scripts/verify_signed_url.ts",
    "verify:text-safety": "pnpm -w exec tsx scripts/verify_text_safety.ts",
    "verify:stage12": "pnpm -w exec tsx scripts/verify_stage12.ts",
    "verify:all": "pnpm verify:cold-start && pnpm verify:stage10 && pnpm verify:signed-url && pnpm verify:text-safety",
    "prepare": "husky",
    "gate:audit": "bash tools/audit/run_full_audit_v3.sh",
    "gate:risk": "bash tools/audit/run_risk_pack_v1.sh",
    "gate:health": "bash tools/health/run_health_pack.sh",
    "gate:commercial": "bash tools/gate/run_commercial_seal.sh"
  },
  "devDependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.5",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "@typescript-eslint/typescript-estree": "^8.52.0",
    "ajv": "^8.17.1",
    "axios": "^1.6.0",
    "glob": "^13.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jscpd": "^4.0.5",
    "jsonwebtoken": "^9.0.2",
    "knip": "^5.80.2",
    "lint-staged": "^16.2.7",
    "prettier": "^3.2.5",
    "prisma": "5.22.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "turbo": "^2.1.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@9.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "pnpm --prefix apps/web lint"
    ],
    "apps/api/**/*.{ts,tsx}": [
      "pnpm --prefix apps/api lint"
    ],
    "**/*.{json,md,yml,yaml}": [
      "prettier --check"
    ]
  },
  "dependencies": {
    "@formatjs/icu-messageformat-parser": "^3.0.2",
    "dotenv": "^16.0.0",
    "express": "^4.19.2",
    "jszip": "^3.10.1",
    "mammoth": "^1.11.0",
    "pg": "^8.16.3",
    "replicate": "^1.4.0",
    "xmlbuilder2": "^4.0.3",
    "zod": "^4.3.5"
  }
}
