# DO NOT COMMIT THIS FILE.

export P7_DEPLOY_BLUE_CMD='set -euo pipefail; echo "[blue] deploying..."; sleep 1; echo "[blue] done"'
export P7_DEPLOY_GREEN_CMD='set -euo pipefail; echo "[green] deploying..."; sleep 1; echo "[green] done"'
export P7_CUTOVER_TO_GREEN_CMD='set -euo pipefail; echo "[cutover] switching traffic..."; sleep 1; echo "[cutover] done"'
export P7_ROLLBACK_TO_BLUE_CMD='set -euo pipefail; echo "[rollback] rolling back..."; sleep 1; echo "[rollback] done"'

# Using google.com as a dummy "always up" healthcheck target for the drill
export P7_HEALTHCHECK_URL_BLUE='https://www.google.com'
export P7_HEALTHCHECK_URL_GREEN='https://www.google.com'
export P7_HEALTHCHECK_URL_LIVE='https://www.google.com'

export P7_HEALTH_TIMEOUT_SEC='10'
export P7_HEALTH_INTERVAL_SEC='1'
