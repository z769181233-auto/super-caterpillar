# DO NOT COMMIT THIS FILE. (P8 Local Secrets)

# P8-2 Incident Drill Mocks
export P8_INCIDENT_INJECT_CMD="echo '[MOCK] Injecting incident...' && touch /tmp/p8_incident_active"
export P8_INCIDENT_OBSERVE_CMD="if [ -f /tmp/p8_incident_active ]; then echo 'ALERT TRIGGERED SEVERITY: P0'; else echo 'NORMAL'; fi"
# Recovery command removes the active flag
export P8_INCIDENT_RECOVER_CMD="echo '[MOCK] Recovering...' && rm -f /tmp/p8_incident_active"
export P8_INCIDENT_TIMEOUT_SEC='5'
export P8_INCIDENT_INTERVAL_SEC='1'

# P8-3 Cost Circuit Breaker Drill Mocks
export P8_COST_SPIKE_CMD="echo '[MOCK] Spiking cost...' && touch /tmp/p8_cb_tripped"
export P8_CB_STATUS_CMD="if [ -f /tmp/p8_cb_tripped ]; then echo 'CIRCUIT BREAKER: TRIPPED'; else echo 'STATUS: NORMAL'; fi"
# Reset command removes the tripped flag
export P8_CB_RESET_CMD="echo '[MOCK] Resetting CB...' && rm -f /tmp/p8_cb_tripped"
export P8_CB_TIMEOUT_SEC='5'
export P8_CB_INTERVAL_SEC='1'
